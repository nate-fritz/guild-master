@page "/"
@using GuildMaster.Services
@inject GameConsole GameConsole
@inject GameEngine GameEngine
@inject IJSRuntime JS

<PageTitle>GuildMaster (Alpha Build)</PageTitle>

<div class="game-container">
    <div class="console-output" id="consoleOutput" @ref="outputDiv">
        @for (int i = 0; i < outputLines.Count; i++)
        {
            @if (unreadMarkerIndex == i)
            {
                <div class="unread-divider">new</div>
            }
            <div>@((MarkupString)outputLines[i])</div>
        }
    </div>

    <div class="jump-pill" @onclick="JumpToPresent" title="Ctrl+End">&#9660; new text below</div>

    <div class="console-input">
        <span class="prompt">&gt;</span>
        <input @ref="inputField"
               @bind="currentInput"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown"
               placeholder="What do you do?" />
    </div>
</div>

@code {
    private List<string> outputLines = new();
    private string currentInput = "";
    private ElementReference outputDiv;
    private ElementReference inputField;
    private bool awaitingName = false;
    private bool awaitingClass = false;
    private string pendingPlayerName = "";
    private List<string> commandHistory = new();
    private int historyIndex = -1;
    private const int MAX_HISTORY_SIZE = 25;

    // Scroll UX state: pinned = view glued to the bottom; the unread marker
    // sits before the first line the player hasn't seen yet (either where a
    // long command output was anchored, or where text arrived while they
    // were reading scrollback).
    private bool scrollPinned = true;
    private int? unreadMarkerIndex = null;
    private int burstStartIndex = 0;
    private DotNetObjectReference<Home>? selfRef;

    [JSInvokable]
    public void OnScrollPinnedChanged(bool pinned)
    {
        scrollPinned = pinned;
    }

    [JSInvokable]
    public async Task OnAnchoredToNewText()
    {
        // Long output got anchored at its top; the divider marks the boundary.
        unreadMarkerIndex = burstStartIndex;
        await InvokeAsync(StateHasChanged);
    }

    private async Task JumpToPresent()
    {
        await JS.InvokeVoidAsync("gmConsole.scrollToBottom");
        await inputField.FocusAsync();
    }

    protected override void OnInitialized()
    {
        GameConsole.OnOutput += HandleOutput;
        GameConsole.OnClear += HandleClear;

        GuildMaster.Services.Console.Initialize(GameConsole);
        GuildMaster.Services.AnsiConsole.Initialize(GameConsole);

        // Set callback for combat state changes
        GameEngine.SetStateChangedCallback(() => InvokeAsync(StateHasChanged));

        ShowTitle();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gmConsole.init", "consoleOutput", selfRef);

            // Page breaks are retired: long output anchors the view to the
            // top of the new text instead (see console-ui.js afterRender).
            GuildMaster.Helpers.TextHelper.ViewportLinesPerPage = int.MaxValue;

            await inputField.FocusAsync();
        }

        // Follows output only while the player is at the bottom; scrolled-up
        // readers stay where they are (the jump pill offers the way back).
        try
        {
            await JS.InvokeVoidAsync("gmConsole.afterRender");
        }
        catch
        {
            // Ignore scroll errors during teardown/initialization
        }
    }
    
